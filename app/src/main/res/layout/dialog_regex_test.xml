<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tool_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        app:title="@string/debug_regex_test"
        app:titleTextAppearance="@style/ToolbarTitle"
        app:popupTheme="@style/AppTheme.PopupOverlay" />

    <io.legado.app.ui.widget.NoChildScrollNestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/replace_rule"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorHint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <io.legado.app.ui.widget.text.TextInputLayout
                    android:id="@+id/til_pattern"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <io.legado.app.lib.theme.view.ThemeEditText
                        android:id="@+id/et_pattern"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:typeface="monospace"
                        tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />
                </io.legado.app.ui.widget.text.TextInputLayout>

                <io.legado.app.lib.theme.view.ThemeCheckBox
                    android:id="@+id/cb_use_regex"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/use_regex"
                    tools:ignore="TouchTargetSizeCheck" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/replace_to"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorHint" />

            <io.legado.app.ui.widget.text.TextInputLayout
                android:id="@+id/til_replacement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <io.legado.app.lib.theme.view.ThemeEditText
                    android:id="@+id/et_replacement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:typeface="monospace"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />
            </io.legado.app.ui.widget.text.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/test_input"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorHint" />

                <TextView
                    android:id="@+id/tv_live_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/drawable_live_dot"
                    android:drawablePadding="4dp"
                    android:text="@string/realtime_preview"
                    android:textSize="11sp"
                    android:textColor="#4CAF50" />

            </LinearLayout>

            <io.legado.app.lib.theme.view.ThemeEditText
                android:id="@+id/et_test_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="80dp"
                android:background="@drawable/bg_edit_text_border"
                android:gravity="start|top"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textSize="14sp"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/match_result"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorHint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical"
                android:background="@color/background"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/match_result"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorHint" />

                    <TextView
                        android:id="@+id/tv_match_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary"
                        android:background="@drawable/bg_match_count_badge"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        tools:text="3 处匹配" />

                </LinearLayout>

                <io.legado.app.ui.widget.text.ScrollTextView
                    android:id="@+id/tv_match_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="60dp"
                    android:textSize="14sp"
                    android:textIsSelectable="true"
                    android:textColor="@color/secondaryText"
                    tools:text="匹配结果将显示在这里" />

                <LinearLayout
                    android:id="@+id/ll_replace_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_replace_preview"
                    android:padding="10dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/replace_preview"
                        android:textSize="11sp"
                        android:textColor="#E65100" />

                    <io.legado.app.ui.widget.text.ScrollTextView
                        android:id="@+id/tv_replace_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="13sp"
                        android:textIsSelectable="true"
                        android:textColor="@color/primaryText"
                        tools:text="替换预览结果" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_match_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_match_info"
                    android:padding="10dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/tv_match_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/secondaryText"
                        tools:text="匹配次数: 3 次\n位置 1: 索引 4-14\n位置 2: 索引 23-33" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_status_success"
                android:padding="10dp">

                <ImageView
                    android:id="@+id/iv_status_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_check"
                    app:tint="#388E3C"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="13sp"
                    android:textColor="#388E3C"
                    tools:text="正则表达式有效，匹配成功" />

            </LinearLayout>

        </LinearLayout>

    </io.legado.app.ui.widget.NoChildScrollNestedScrollView>

</LinearLayout>
